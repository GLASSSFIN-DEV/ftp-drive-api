// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
  schemas = ["drive"]

}

enum RecordStatus {
  ACTIVE
  NOT_ACTIVE

  @@schema("drive")
}

enum SubmissionAction {
  WAITING
  APPROVED
  REJECTED

  @@schema("drive")
}

enum SharePermission {
  READ_ONLY
  READ_WRITE

  @@schema("drive")
}

model Option {
  id        String   @id @default(uuid())
  key       String
  json      Json?
  createdAt DateTime @default(now())

  @@schema("drive")
  @@index([createdAt(sort: Desc)])
}

model Account {
  id           String       @id @default(uuid())
  dirId        String
  username     String
  fullname     String?
  email        String?
  provider     String
  rbacId       String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime?
  recordStatus RecordStatus @default(NOT_ACTIVE)

  directorate             Diretorate      @relation(fields: [dirId], references: [id])
  rbac                    Rbac            @relation(fields: [rbacId], references: [id])
  directorates            Diretorate[]    @relation("dirAccounts")
  submissions             Submission[]    @relation("subAccounts")
  rbacs                   Rbac[]          @relation("rbacAccounts")
  subsActionBy            Submission[]    @relation("subActionByAccounts")
  folders                 Folder[]        @relation("folderAccounts")
  files                   File[]          @relation("fileAccounts")
  traces                  Trace[]         @relation("traceAccounts")
  sessions                Session[]       @relation("sessionAccount")
  folderSharingAccounts   FolderSharing[] @relation("folderSharingAccounts")
  folderSharingToAccounts FolderSharing[] @relation("folderSharingToAccounts")
  fileSharingAccounts     FileSharing[]   @relation("fileSharingAccounts")
  fileSharingToAccounts   FileSharing[]   @relation("fileSharingToAccounts")

  @@schema("drive")
  @@index([dirId])
  @@index([rbacId])
  @@index([provider])
  @@index([recordStatus])
  @@index([createdAt(sort: Desc)])
  @@index([username, provider])
}

model Session {
  id           String       @id @default(uuid())
  accountId    String
  appCode      String       @default("main_app")
  jwtHash      String
  recordStatus RecordStatus @default(NOT_ACTIVE)
  createdAt    DateTime     @default(now())

  account Account @relation("sessionAccount", fields: [accountId], references: [id])

  @@schema("drive")
  @@index([accountId])
  @@index([jwtHash])
  @@index([recordStatus])
  @@index([createdAt(sort: Desc)])
  @@index([accountId, appCode])

}

model Diretorate {
  id           String       @id @default(uuid())
  name         String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime?
  accountId    String?
  recordStatus RecordStatus @default(NOT_ACTIVE)

  accounts Account[]
  account  Account?  @relation("dirAccounts", fields: [accountId], references: [id])

  @@schema("drive")
  @@index([accountId])
  @@index([recordStatus])
  @@index([createdAt(sort: Desc)])
  @@index([name])
}

model Submission {
  id               String           @id @default(uuid())
  accountId        String?
  status           SubmissionAction @default(WAITING)
  verificationCode String           @unique
  expiredAt        DateTime
  actionBy         String?
  actionJson       Json?
  actionAt         DateTime?
  createdAt        DateTime         @default(now())

  account         Account? @relation("subAccounts", fields: [accountId], references: [id])
  accountActionBy Account? @relation("subActionByAccounts", fields: [actionBy], references: [id])

  @@schema("drive")
  @@index([accountId])
  @@index([actionBy])
  @@index([status])
  @@index([expiredAt])
  @@index([createdAt(sort: Desc)])
}

model Rbac {
  id           String       @id @default(uuid())
  name         String
  value        Json?
  accountId    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime?
  recordStatus RecordStatus @default(NOT_ACTIVE)

  account  Account?  @relation("rbacAccounts", fields: [accountId], references: [id])
  accounts Account[]

  @@schema("drive")
  @@index([accountId])
  @@index([recordStatus])
  @@index([createdAt(sort: Desc)])
}

model Folder {
  id           String       @id @default(uuid())
  parentId     String?
  accountId    String
  folderName   String
  source       Json
  createdAt    DateTime     @default(now())
  updatedAt    DateTime?
  recordStatus RecordStatus @default(NOT_ACTIVE)

  parent         Folder?         @relation("children", fields: [parentId], references: [id])
  folders        Folder[]        @relation("children")
  account        Account         @relation("folderAccounts", fields: [accountId], references: [id])
  files          File[]
  folderSharings FolderSharing[]

  @@schema("drive")
  @@index([parentId])
  @@index([accountId])
  @@index([recordStatus])
  @@index([createdAt(sort: Desc)])
  @@index([folderName])
  @@index([accountId, parentId])
  @@index([accountId, folderName])
}

model File {
  id           String       @id @default(uuid())
  folderId     String
  fileName     String
  fileHash     String?
  fileSize     Int
  fileType     String
  source       Json
  createdAt    DateTime     @default(now())
  updatedAt    DateTime?
  accountId    String
  recordStatus RecordStatus @default(NOT_ACTIVE)

  account      Account       @relation("fileAccounts", fields: [accountId], references: [id])
  folder       Folder        @relation(fields: [folderId], references: [id])
  fileSharings FileSharing[]

  @@schema("drive")
  @@index([folderId])
  @@index([accountId])
  @@index([recordStatus])
  @@index([createdAt(sort: Desc)])
  @@index([fileHash])
  @@index([fileType])
  @@index([fileName])
  @@index([folderId, fileName])
  @@index([accountId, folderId])
}

model FolderSharing {
  id            String          @id @default(uuid())
  folderId      String
  toAccountId   String
  expiredAt     DateTime?
  permission    SharePermission @default(READ_ONLY)
  generatedLink String
  accountId     String
  createdAt     DateTime        @default(now())
  recordStatus  RecordStatus    @default(NOT_ACTIVE)

  account   Account @relation("folderSharingAccounts", fields: [accountId], references: [id])
  toAccount Account @relation("folderSharingToAccounts", fields: [toAccountId], references: [id])
  folder    Folder  @relation(fields: [folderId], references: [id])

  @@schema("drive")

  @@index([folderId])
  @@index([accountId])
  @@index([toAccountId])
  @@index([generatedLink])
  @@index([expiredAt])
  @@index([recordStatus])
}

model FileSharing {
  id            String          @id @default(uuid())
  fileId        String
  toAccountId   String
  expiredAt     DateTime?
  permission    SharePermission @default(READ_ONLY)
  generatedLink String
  accountId     String
  createdAt     DateTime        @default(now())
  recordStatus  RecordStatus    @default(NOT_ACTIVE)

  account   Account @relation("fileSharingAccounts", fields: [accountId], references: [id])
  toAccount Account @relation("fileSharingToAccounts", fields: [toAccountId], references: [id])
  file      File    @relation(fields: [fileId], references: [id])

  @@schema("drive")

  @@index([fileId])
  @@index([accountId])
  @@index([toAccountId])
  @@index([generatedLink])
  @@index([expiredAt])
  @@index([recordStatus])
}

model Trace {
  id             String   @id
  accountId      String?
  url            String
  method         String
  status         Int
  responseTimeMs Int
  createdAt      DateTime @default(now())

  account Account? @relation("traceAccounts", fields: [accountId], references: [id])

  @@schema("drive")
  @@index([accountId])
  @@index([status])
  @@index([method])
  @@index([createdAt(sort: Desc)])
  @@index([url])
}

model TraceSpan {
  id         String   @id @default(uuid())
  traceId    String?
  json       Json?
  context    String
  durationMs Int
  createdAt  DateTime @default(now())

  @@schema("drive")
  @@index([traceId])
  @@index([context])
  @@index([createdAt(sort: Desc)])
  @@index([durationMs])
}
