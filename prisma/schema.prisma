// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["drive"]
}

enum RecordStatus {
  ACTIVE
  NOT_ACTIVE
  DEAD

  @@schema("drive")
}

enum SharePermission {
  READ_ONLY
  READ_WRITE

  @@schema("drive")
}

model Option {
  id        String   @id @default(uuid())
  key       String
  json      Json?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@schema("drive")
}

model Account {
  id           String       @id @default(uuid())
  dirId        String?
  username     String       @unique
  fullname     String?
  email        String?
  provider     String
  rbacId       String?
  accountInfo  Json?
  quota        Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime?
  recordStatus RecordStatus @default(NOT_ACTIVE)

  directorate             Diretorate?     @relation(fields: [dirId], references: [id])
  rbac                    Rbac?           @relation(fields: [rbacId], references: [id])
  directorates            Diretorate[]    @relation("dirAccounts")
  rbacs                   Rbac[]          @relation("rbacAccounts")
  folders                 Folder[]        @relation("folderAccounts")
  files                   File[]          @relation("fileAccounts")
  traces                  Trace[]         @relation("traceAccounts")
  sessions                Session[]       @relation("sessionAccount")
  folderSharingAccounts   FolderSharing[] @relation("folderSharingAccounts")
  folderSharingToAccounts FolderSharing[] @relation("folderSharingToAccounts")
  fileSharingAccounts     FileSharing[]   @relation("fileSharingAccounts")
  fileSharingToAccounts   FileSharing[]   @relation("fileSharingToAccounts")
  fileHistories           FileHistory[]

  @@index([dirId])
  @@index([rbacId])
  @@index([provider])
  @@index([recordStatus])
  @@index([createdAt(sort: Desc)])
  @@index([username, provider])
  @@schema("drive")
}

model Session {
  id           String       @id @default(uuid())
  accountId    String
  appCode      String       @default("main_app")
  jwtHash      String
  recordStatus RecordStatus @default(NOT_ACTIVE)
  createdAt    DateTime     @default(now())

  account Account @relation("sessionAccount", fields: [accountId], references: [id])

  @@index([accountId])
  @@index([jwtHash])
  @@index([recordStatus])
  @@index([createdAt(sort: Desc)])
  @@index([accountId, appCode])
  @@schema("drive")
}

model Diretorate {
  id           String       @id @default(uuid())
  name         String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime?
  accountId    String?
  recordStatus RecordStatus @default(NOT_ACTIVE)

  accounts Account[]
  account  Account?  @relation("dirAccounts", fields: [accountId], references: [id])

  @@index([accountId])
  @@index([recordStatus])
  @@index([createdAt(sort: Desc)])
  @@index([name])
  @@schema("drive")
}

model Rbac {
  id           String       @id @default(uuid())
  name         String
  value        Json?
  accountId    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime?
  recordStatus RecordStatus @default(NOT_ACTIVE)

  account  Account?  @relation("rbacAccounts", fields: [accountId], references: [id])
  accounts Account[]

  @@index([accountId])
  @@index([recordStatus])
  @@index([createdAt(sort: Desc)])
  @@schema("drive")
}

model Folder {
  id            String                   @id @default(uuid())
  parentId      String?
  accountId     String
  folderName    String
  source        Json
  label         Json[]                   @default([])
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime?
  recordStatus  RecordStatus             @default(NOT_ACTIVE)
  folderNameFts Unsupported("tsvector")?

  parent         Folder?         @relation("children", fields: [parentId], references: [id])
  folders        Folder[]        @relation("children")
  account        Account         @relation("folderAccounts", fields: [accountId], references: [id])
  files          File[]
  folderSharings FolderSharing[]

  @@index([folderName(ops: raw("gin_trgm_ops"))], type: Gin, map: "Folder_folderName_trgm_idx")
  @@index([folderNameFts], type: Gin)
  @@index([parentId])
  @@index([accountId])
  @@index([recordStatus])
  @@index([createdAt(sort: Desc)])
  @@index([folderName])
  @@index([accountId, parentId])
  @@index([accountId, folderName])
  @@schema("drive")
}

model File {
  id           String                   @id @default(uuid())
  folderId     String
  fileName     String
  fileHash     String?
  fileSize     Int
  fileType     String
  source       Json
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime?
  accountId    String
  recordStatus RecordStatus             @default(NOT_ACTIVE)
  fileNameFts  Unsupported("tsvector")?

  account       Account       @relation("fileAccounts", fields: [accountId], references: [id])
  folder        Folder        @relation(fields: [folderId], references: [id])
  fileSharings  FileSharing[]
  fileHistories FileHistory[]
  fileVectors   FileVector[]

  @@index([fileName(ops: raw("gin_trgm_ops"))], type: Gin, map: "File_fileName_trgm_idx")
  @@index([fileNameFts], type: Gin)
  @@unique([folderId, fileName])
  @@index([folderId])
  @@index([accountId])
  @@index([recordStatus])
  @@index([createdAt(sort: Desc)])
  @@index([fileHash])
  @@index([fileType])
  @@index([folderId, fileName])
  @@index([accountId, folderId])
  @@schema("drive")
}

model FileHistory {
  id        String   @id @default(uuid())
  fileId    String
  json      Json
  version   Int
  accountId String
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id])
  file    File    @relation(fields: [fileId], references: [id])

  @@index([fileId, accountId])
  @@schema("drive")
}

model FolderSharing {
  id            String          @id @default(uuid())
  folderId      String
  toAccountId   String
  expiredAt     DateTime?
  permission    SharePermission @default(READ_ONLY)
  generatedLink String
  accountId     String
  createdAt     DateTime        @default(now())
  recordStatus  RecordStatus    @default(NOT_ACTIVE)

  account   Account @relation("folderSharingAccounts", fields: [accountId], references: [id])
  toAccount Account @relation("folderSharingToAccounts", fields: [toAccountId], references: [id])
  folder    Folder  @relation(fields: [folderId], references: [id])

  @@index([folderId])
  @@index([accountId])
  @@index([toAccountId])
  @@index([generatedLink])
  @@index([expiredAt])
  @@index([recordStatus])
  @@schema("drive")
}

model FileSharing {
  id            String          @id @default(uuid())
  fileId        String
  toAccountId   String
  expiredAt     DateTime?
  permission    SharePermission @default(READ_ONLY)
  generatedLink String
  accountId     String
  createdAt     DateTime        @default(now())
  recordStatus  RecordStatus    @default(NOT_ACTIVE)

  account   Account @relation("fileSharingAccounts", fields: [accountId], references: [id])
  toAccount Account @relation("fileSharingToAccounts", fields: [toAccountId], references: [id])
  file      File    @relation(fields: [fileId], references: [id])

  @@index([fileId])
  @@index([accountId])
  @@index([toAccountId])
  @@index([generatedLink])
  @@index([expiredAt])
  @@index([recordStatus])
  @@schema("drive")
}

model Trace {
  id             String   @id
  accountId      String?
  url            String
  method         String
  status         Int
  responseTimeMs Int
  createdAt      DateTime @default(now())

  account Account? @relation("traceAccounts", fields: [accountId], references: [id])

  @@index([accountId])
  @@index([status])
  @@index([method])
  @@index([createdAt(sort: Desc)])
  @@index([url])
  @@schema("drive")
}

model TraceSpan {
  id         String   @id @default(uuid())
  traceId    String?
  json       Json?
  context    String
  durationMs Int
  createdAt  DateTime @default(now())

  @@index([traceId])
  @@index([context])
  @@index([createdAt(sort: Desc)])
  @@index([durationMs])
  @@schema("drive")
}

model TusUpload {
  id        String    @id
  siteId    Int
  ftpHost   String    @default("")
  tempPath  String
  size      Int?
  offset    Int       @default(0)
  metadata  Json?
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  @@index([expiresAt])
  @@index([createdAt(sort: Desc)])
  @@schema("drive")
}

model FileVector {
  id         String                      @id @default(uuid())
  fileId     String
  content    String
  metadata   Json
  embedding  Unsupported("vector(768)")?
  createdAt  DateTime                    @default(now())
  intent     Json[]                      @default([])
  contentFts Unsupported("tsvector")?
  pageNumber Int

  file File @relation(fields: [fileId], references: [id])

  @@index([content(ops: raw("gin_trgm_ops"))], type: Gin, map: "FileVector_content_trgm_idx")
  @@index([contentFts], type: Gin)
  @@index([fileId])
  @@schema("drive")
}

model Prompt {
  id        String   @id @default(uuid())
  name      String   @unique
  content   String
  createdAt DateTime @default(now())

  @@schema("drive")
}
