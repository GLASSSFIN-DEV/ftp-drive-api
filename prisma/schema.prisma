// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["drive"]
}

enum RecordStatus {
  ACTIVE
  NOT_ACTIVE

  @@schema("drive")
}

enum SharePermission {
  READ_ONLY
  READ_WRITE

  @@schema("drive")
}

model Option {
  id        String   @id @default(uuid())
  key       String
  json      Json?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@schema("drive")
}

model Account {
  id           String       @id @default(uuid())
  dirId        String?
  username     String       @unique
  fullname     String?
  email        String?
  provider     String
  rbacId       String?
  accountInfo  Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime?
  recordStatus RecordStatus @default(NOT_ACTIVE)

  directorate             Diretorate?     @relation(fields: [dirId], references: [id])
  rbac                    Rbac?           @relation(fields: [rbacId], references: [id])
  directorates            Diretorate[]    @relation("dirAccounts")
  rbacs                   Rbac[]          @relation("rbacAccounts")
  folders                 Folder[]        @relation("folderAccounts")
  files                   File[]          @relation("fileAccounts")
  traces                  Trace[]         @relation("traceAccounts")
  sessions                Session[]       @relation("sessionAccount")
  folderSharingAccounts   FolderSharing[] @relation("folderSharingAccounts")
  folderSharingToAccounts FolderSharing[] @relation("folderSharingToAccounts")
  fileSharingAccounts     FileSharing[]   @relation("fileSharingAccounts")
  fileSharingToAccounts   FileSharing[]   @relation("fileSharingToAccounts")
  nodeAccounts            Node[]          @relation("nodeAccounts")
  nodeShareAccounts       NodeShare[]     @relation("nodeShareAccounts")
  nodeShareToAccounts     NodeShare[]     @relation("nodeShareToAccounts")

  @@index([dirId])
  @@index([rbacId])
  @@index([provider])
  @@index([recordStatus])
  @@index([createdAt(sort: Desc)])
  @@index([username, provider])
  @@schema("drive")
}

model Session {
  id           String       @id @default(uuid())
  accountId    String
  appCode      String       @default("main_app")
  jwtHash      String
  recordStatus RecordStatus @default(NOT_ACTIVE)
  createdAt    DateTime     @default(now())

  account Account @relation("sessionAccount", fields: [accountId], references: [id])

  @@index([accountId])
  @@index([jwtHash])
  @@index([recordStatus])
  @@index([createdAt(sort: Desc)])
  @@index([accountId, appCode])
  @@schema("drive")
}

model Diretorate {
  id           String       @id @default(uuid())
  name         String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime?
  accountId    String?
  recordStatus RecordStatus @default(NOT_ACTIVE)

  accounts Account[]
  account  Account?  @relation("dirAccounts", fields: [accountId], references: [id])

  @@index([accountId])
  @@index([recordStatus])
  @@index([createdAt(sort: Desc)])
  @@index([name])
  @@schema("drive")
}

model Rbac {
  id           String       @id @default(uuid())
  name         String
  value        Json?
  accountId    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime?
  recordStatus RecordStatus @default(NOT_ACTIVE)

  account  Account?  @relation("rbacAccounts", fields: [accountId], references: [id])
  accounts Account[]

  @@index([accountId])
  @@index([recordStatus])
  @@index([createdAt(sort: Desc)])
  @@schema("drive")
}

model Folder {
  id           String       @id @default(uuid())
  parentId     String?
  accountId    String
  folderName   String
  source       Json
  createdAt    DateTime     @default(now())
  updatedAt    DateTime?
  recordStatus RecordStatus @default(NOT_ACTIVE)

  parent         Folder?         @relation("children", fields: [parentId], references: [id])
  folders        Folder[]        @relation("children")
  account        Account         @relation("folderAccounts", fields: [accountId], references: [id])
  files          File[]
  folderSharings FolderSharing[]

  @@index([parentId])
  @@index([accountId])
  @@index([recordStatus])
  @@index([createdAt(sort: Desc)])
  @@index([folderName])
  @@index([accountId, parentId])
  @@index([accountId, folderName])
  @@schema("drive")
}

model File {
  id           String       @id @default(uuid())
  folderId     String
  fileName     String
  fileHash     String?
  fileSize     Int
  fileType     String
  source       Json
  createdAt    DateTime     @default(now())
  updatedAt    DateTime?
  accountId    String
  recordStatus RecordStatus @default(NOT_ACTIVE)

  account      Account       @relation("fileAccounts", fields: [accountId], references: [id])
  folder       Folder        @relation(fields: [folderId], references: [id])
  fileSharings FileSharing[]

  @@index([folderId])
  @@index([accountId])
  @@index([recordStatus])
  @@index([createdAt(sort: Desc)])
  @@index([fileHash])
  @@index([fileType])
  @@index([fileName])
  @@index([folderId, fileName])
  @@index([accountId, folderId])
  @@schema("drive")
}

model FolderSharing {
  id            String          @id @default(uuid())
  folderId      String
  toAccountId   String
  expiredAt     DateTime?
  permission    SharePermission @default(READ_ONLY)
  generatedLink String
  accountId     String
  createdAt     DateTime        @default(now())
  recordStatus  RecordStatus    @default(NOT_ACTIVE)

  account   Account @relation("folderSharingAccounts", fields: [accountId], references: [id])
  toAccount Account @relation("folderSharingToAccounts", fields: [toAccountId], references: [id])
  folder    Folder  @relation(fields: [folderId], references: [id])

  @@index([folderId])
  @@index([accountId])
  @@index([toAccountId])
  @@index([generatedLink])
  @@index([expiredAt])
  @@index([recordStatus])
  @@schema("drive")
}

model FileSharing {
  id            String          @id @default(uuid())
  fileId        String
  toAccountId   String
  expiredAt     DateTime?
  permission    SharePermission @default(READ_ONLY)
  generatedLink String
  accountId     String
  createdAt     DateTime        @default(now())
  recordStatus  RecordStatus    @default(NOT_ACTIVE)

  account   Account @relation("fileSharingAccounts", fields: [accountId], references: [id])
  toAccount Account @relation("fileSharingToAccounts", fields: [toAccountId], references: [id])
  file      File    @relation(fields: [fileId], references: [id])

  @@index([fileId])
  @@index([accountId])
  @@index([toAccountId])
  @@index([generatedLink])
  @@index([expiredAt])
  @@index([recordStatus])
  @@schema("drive")
}

model Trace {
  id             String   @id
  accountId      String?
  url            String
  method         String
  status         Int
  responseTimeMs Int
  createdAt      DateTime @default(now())

  account Account? @relation("traceAccounts", fields: [accountId], references: [id])

  @@index([accountId])
  @@index([status])
  @@index([method])
  @@index([createdAt(sort: Desc)])
  @@index([url])
  @@schema("drive")
}

model TraceSpan {
  id         String   @id @default(uuid())
  traceId    String?
  json       Json?
  context    String
  durationMs Int
  createdAt  DateTime @default(now())

  @@index([traceId])
  @@index([context])
  @@index([createdAt(sort: Desc)])
  @@index([durationMs])
  @@schema("drive")
}

// File and Folder would be removed
model Node {
  id           String       @id @default(uuid())
  parentId     String?
  name         String
  source       Json
  isDirectory  Boolean
  file         Json?
  folder       Json?
  accountId    String
  createdAt    DateTime
  updatedAt    DateTime?
  recordStatus RecordStatus @default(ACTIVE)

  account    Account     @relation("nodeAccounts", fields: [accountId], references: [id])
  parent     Node?       @relation("children", fields: [parentId], references: [id])
  nodes      Node[]      @relation("children")
  nodeShares NodeShare[]

  @@index([accountId])
  @@index([parentId])
  @@index([recordStatus])
  @@index([isDirectory])
  @@schema("drive")
}

model NodeShare {
  id            String          @id @default(uuid())
  toAccountId   String
  nodeId        String
  accountId     String
  expiredAt     DateTime?
  permission    SharePermission @default(READ_ONLY)
  generatedLink String
  createdAt     DateTime

  account   Account @relation("nodeShareAccounts", fields: [accountId], references: [id])
  toAccount Account @relation("nodeShareToAccounts", fields: [toAccountId], references: [id])
  node      Node    @relation(fields: [nodeId], references: [id])

  @@index([accountId])
  @@index([toAccountId])
  @@index([nodeId])

  @@schema("drive")
}
